PORT=4000
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
USDC_ISSUER=...
KOTANI_API_KEY=
KOTANI_USE_SANDBOX=true

# Supabase (required — all data is stored here)
# Go to https://supabase.com → New Project → Copy Project URL & anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=...

# AI Provider API Keys (optional — when set, Twaala becomes truly intelligent)
# Get a free Gemini key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Get a free Groq key: https://console.groq.com/keys
GROQ_API_KEY=

# Africa's Talking SMS (optional — for recipient SMS notifications)
# Sign up at https://africastalking.com — use 'sandbox' for testing
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=TWALA
