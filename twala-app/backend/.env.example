PORT=4000
STELLAR_NETWORK=TESTNET
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
USDC_ISSUER=...

# ============================================================
# Kotani Pay — On/Off-ramp to Mobile Money (required for real transfers)
# ============================================================
# Sign up: https://backoffice.kotanipay.com → API Keys → Generate
# Sandbox: https://sandbox-api.kotanipay.io
# Production: https://api.kotanipay.io
# Empty = demo mode (simulated 5s completion, no real money)
KOTANI_API_KEY=
KOTANI_USE_SANDBOX=true
# Escrow Stellar address where USDC is sent for Kotani offramp
# Kotani provides this when you create an offramp — leave empty to use issuer in demo
KOTANI_ESCROW_ADDRESS=

# ============================================================
# Supabase — Database (required — all data stored here)
# ============================================================
# Go to https://supabase.com → New Project → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=...

# ============================================================
# AI Provider API Keys (optional — enables AI agent features)
# ============================================================
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# ============================================================
# Africa's Talking SMS (optional — recipient SMS notifications)
# ============================================================
# Sign up: https://africastalking.com → Sandbox → Settings → API Key
# Username is always 'sandbox' for dev, your app name for production
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=TWAALA
